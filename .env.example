# Trading Bot Environment Variables
# Copy this file to .env and fill in your actual values

# Safe runtime defaults
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081
GATEWAY_PORT=8080
BACKEND_URL=http://localhost:8081
TRADING_EXECUTION_MODE=paper
TRADING_EXCHANGE_PROVIDER=paper
TRADING_LIVE_ENABLED=false
TRADING_BYBIT_DOMAIN=TESTNET_DOMAIN

# Exchange Credentials (only required for external exchange execution)
TRADING_BINANCE_API_KEY=
TRADING_BINANCE_API_SECRET=
TRADING_BYBIT_API_KEY=
TRADING_BYBIT_API_SECRET=
TRADING_DYDX_ETH_PRIVATE_KEY=

# Grok AI API Key (for Agentic AI)
GROK_API_KEY=
LLM_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=

# Database Configuration (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/trading_bot
DB_USERNAME=tradingbot
DB_PASSWORD=change-me

# Redis Configuration
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Kafka Configuration
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Agent Configuration
AGENT_ORCHESTRATOR_ENABLED=true
AGENT_ORCHESTRATOR_LOOP_INTERVAL=30000
AGENT_LLM_GROK_ENABLED=true

# Security
JWT_SECRET=change-me-before-production
